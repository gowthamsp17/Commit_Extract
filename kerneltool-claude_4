def resolve_paths(args):
    base = args.data_dir if args.data_dir else os.getcwd()
    df_map      = {b: os.path.join(base, os.path.basename(p)) for b, p in DATA_FILES.items()}
    cve         = os.path.join(base, os.path.basename(CVE_FILE))
    status      = os.path.join(base, STATUS_FILE)
    status_hist = os.path.join(base, STATUS_HISTORY_FILE)
    return df_map, cve, status, status_hist


def load_csv(path, label, quiet):
    if not os.path.exists(path):
        print(f"✖  File not found: {path}", file=sys.stderr)
        return None
    if not quiet:
        print(f"  Loading {label}…", end=" ", flush=True, file=sys.stderr)
    df = pd.read_csv(path, low_memory=False)
    if not quiet:
        print(f"{len(df):,} rows", file=sys.stderr)
    return df


# ── CVE helpers ───────────────────────────────────────────────────────────

def cve_short_hashes(cve_df, branch):
    col = f"{branch} Fixed Commit"
    if col not in cve_df.columns:
        return set()
    return set(cve_df[col].dropna().astype(str).str.lower().str.strip())


def build_cve_map(cve_df, branch):
    col = f"{branch} Fixed Commit"
    if col not in cve_df.columns:
        return {}
    tmp = cve_df[["CVE Number", col]].dropna(subset=[col]).copy()
    tmp["_sh"] = tmp[col].astype(str).str.lower().str.strip()
    return tmp.groupby("_sh")["CVE Number"].apply(lambda x: ", ".join(x)).to_dict()


def hash_has_cve(full_hash, short_set):
    fh = full_hash.lower()
    return any(fh.startswith(s) for s in short_set)


def hash_to_cves(full_hash, cve_map):
    fh = full_hash.lower()
    found = [v for k, v in cve_map.items() if fh.startswith(k)]
    return ", ".join(found) if found else None


def filter_cve_records(cve_df, cve_ids):
    ids_upper = [c.upper() for c in cve_ids]
    return cve_df[cve_df["CVE Number"].str.upper().isin(ids_upper)].copy()


# ── Version-applicability helper ──────────────────────────────────────────

def get_version_commit_date(df, branch, version):
    """
    Return the CommitDate of any commit whose First Version == version.
    Returns a pandas Timestamp or None if not found.
    """
    version_col = f"{branch} First Version"
    commit_col  = f"{branch} CommitDate"
    if version_col not in df.columns or commit_col not in df.columns:
        return None
    rows = df[df[version_col].fillna("").astype(str).str.strip() == version.strip()]
    if rows.empty:
        return None
    raw = rows.iloc[0][commit_col]
    try:
        return pd.to_datetime(raw, format=DATE_FMT, errors="coerce")
    except Exception:
        return None


def compute_version_applicability(df, branch, version, full_df=None):
    """
    Add a 'Version Applicability' column to df.

    full_df: the unfiltered dataframe — used to find the version's CommitDate
             even when that version was excluded by --version-from/--version-to.

    Logic per row:
      - No fixes present                          → 'no fixes'
      - Last fix CommitDate < version CommitDate  → 'applicable'
      - Last fix CommitDate >= version CommitDate → 'not applicable'
      - Date missing/unparseable                  → 'unknown'
    """
    lookup_df = full_df if full_df is not None else df
    commit_col = f"{branch} CommitDate"

    # Collect Fix-N CommitDate columns in order: Fix-1, Fix-2, …
    fix_date_cols = []
    seen_fix_nums = []
    for c in df.columns:
        if c.startswith("Fix-") and "CommitDate" in c and branch in c:
            fn = c.split()[0]          # "Fix-N"
            if fn not in seen_fix_nums:
                seen_fix_nums.append(fn)
                fix_date_cols.append(c)
    # sort by the numeric suffix: Fix-1 < Fix-2 < …
    fix_date_cols.sort(key=lambda c: int(c.split("-")[1].split()[0]))

    # Also need corresponding hash cols to detect presence
    fix_hash_cols = []
    for fn in [c.split()[0] for c in fix_date_cols]:
        hc = f"{fn} {branch} Commit Hash"
        fix_hash_cols.append(hc if hc in df.columns else None)

    ver_date = get_version_commit_date(lookup_df, branch, version)
    if ver_date is None or pd.isna(ver_date):
        # Can't determine version date — mark everything unknown
        df = df.copy()
        df["Version Applicability"] = "Unknown (version not found)"
        return df

    def _row_applicability(row):
        # Find the last fix that actually has a hash (= exists)
        last_fix_date_col = None
        for hc, dc in zip(fix_hash_cols, fix_date_cols):
            if hc and pd.notna(row.get(hc, None)) and str(row.get(hc, "")).strip():
                last_fix_date_col = dc   # keep updating → ends at last present fix

        if last_fix_date_col is None:
            return "No Fixes"

        raw_date = row.get(last_fix_date_col, None)
        fix_date = pd.to_datetime(raw_date, format=DATE_FMT, errors="coerce")
        if pd.isna(fix_date):
            return "Unknown"

        return "Applicable" if fix_date < ver_date else "Not Applicable"

    df = df.copy()
    df["Version Applicability"] = df.apply(_row_applicability, axis=1)
    return df


# ── Core filtering ────────────────────────────────────────────────────────

def parse_date(s):
    for fmt in ("%Y-%m-%d", "%d/%m/%Y"):
        try:
            return datetime.strptime(s, fmt)
        except ValueError:
            pass
    return None


def apply_filters(df, branch, args, cve_short, commit_hashes_from_cve):
    hash_col      = f"{branch} Commit Hash"
    applic_col    = f"{branch} Applicability"
    commit_col    = f"{branch} CommitDate"
    version_col   = f"{branch} First Version"
    fix_hash_cols = [c for c in df.columns if c.startswith("Fix-") and "Commit Hash" in c]

    mask = pd.Series(True, index=df.index)

    all_hashes = list(args.hash or []) + commit_hashes_from_cve
    if all_hashes:
        hl = [h.lower() for h in all_hashes]
        mask &= df[hash_col].str.lower().apply(
            lambda fh: any(fh.startswith(h) or h.startswith(fh) for h in hl)
        )

    if args.severity:
        mask &= df["Severity"].isin(args.severity)

    if args.subsystem:
        sm = pd.Series(False, index=df.index)
        for kw in args.subsystem:
            sm |= df["Files Changed"].fillna("").str.lower().str.contains(kw.lower(), regex=False)
        mask &= sm

    if args.applicability:
        mask &= df[applic_col].isin(args.applicability)

    # cve-xref: FILTER (removes rows without CVE)
    if args.cve_xref and cve_short is not None:
        mask &= df[hash_col].apply(lambda h: hash_has_cve(h, cve_short))

    if args.cc_stable:
        mask &= df["Cc stable"].str.strip().str.lower() == "yes"
    if args.cc_security:
        mask &= df["Cc security"].str.strip().str.lower() == "yes"

    if args.has_fixes:
        fix_mask = pd.Series(False, index=df.index)
        for fc in fix_hash_cols:
            fix_mask |= df[fc].notna()
        mask &= fix_mask

    if args.date_from or args.date_to:
        dates = pd.to_datetime(df[commit_col], format=DATE_FMT, errors="coerce")
        if args.date_from:
            d = parse_date(args.date_from)
            if d:
                mask &= dates >= d
        if args.date_to:
            d = parse_date(args.date_to)
            if d:
                mask &= dates <= d

    # version range filter
    if args.version_from or args.version_to:
        mask &= version_in_range(df[version_col], args.version_from, args.version_to)

    # exact/prefix version
    if args.version:
        mask &= df[version_col].fillna("").astype(str).str.startswith(args.version)

    if args.search:
        mask &= df["Description"].fillna("").str.lower().str.contains(
            args.search.lower(), regex=False)

    if args.config:
        mask &= df["CONFIG_ Parameters"].fillna("").str.lower().str.contains(
            args.config.lower(), regex=False)

    return df[mask].copy()


