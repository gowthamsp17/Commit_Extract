# ── Version helpers ───────────────────────────────────────────────────────

def parse_version(v):
    parts = []
    for p in str(v).strip().split("."):
        try:
            parts.append(int(p))
        except ValueError:
            parts.append(0)
    return tuple(parts)


def version_in_range(ver_series, from_ver, to_ver):
    parsed = ver_series.fillna("").apply(lambda v: parse_version(v) if v else None)
    mask = pd.Series(True, index=ver_series.index)
    if from_ver:
        fv = parse_version(from_ver)
        mask &= parsed.apply(lambda v: v is not None and v >= fv)
    if to_ver:
        tv = parse_version(to_ver)
        mask &= parsed.apply(lambda v: v is not None and v <= tv)
    return mask


