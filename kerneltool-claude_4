# ── Update-status helpers ─────────────────────────────────────────────────

def _parse_last_run_time(text):
    """Extract the Last Run Time value from a status block string."""
    for line in text.splitlines():
        if line.strip().startswith("Last Run Time"):
            parts = line.split(":", 1)
            if len(parts) == 2:
                return parts[1].strip()
    return None


def _split_status_blocks(text):
    """Split a status file into individual blocks separated by ======= lines."""
    blocks, current = [], []
    for line in text.splitlines():
        current.append(line)
        if line.strip().startswith("=") and len(line.strip()) > 10 and current.count(line) >= 1:
            block_text = "\n".join(current).strip()
            if "Last Run Time" in block_text:
                blocks.append(block_text)
            current = []
    # handle trailing content without a final separator
    leftover = "\n".join(current).strip()
    if "Last Run Time" in leftover:
        blocks.append(leftover)
    return blocks


def print_last_updated(status_path, quiet=False):
    """Print 'Last updated time' banner to stderr at the start of every run."""
    if quiet:
        return
    if not os.path.exists(status_path):
        return
    try:
        with open(status_path, "r") as fh:
            content = fh.read()
        ts = _parse_last_run_time(content)
        if ts:
            print(f"{CYA}Last updated time : {BOLD}{ts}{RST}", file=sys.stderr)
            print(file=sys.stderr)
    except OSError:
        pass


def cmd_show_updates(status_path, status_hist_path, date_filter=None):
    """
    Handle --updates [--date YYYY-MM-DD].

    Without --date  → show update_status.txt (current snapshot).
    With    --date  → show all matching blocks from update_status_history.txt.
    """
    if date_filter is None:
        # Show current status
        if not os.path.exists(status_path):
            print(f"✖  Status file not found: {status_path}", file=sys.stderr)
            sys.exit(1)
        with open(status_path, "r") as fh:
            print(fh.read())
        sys.exit(0)

    # Show historical entries matching the given date
    if not os.path.exists(status_hist_path):
        print(f"✖  History file not found: {status_hist_path}", file=sys.stderr)
        sys.exit(1)

    with open(status_hist_path, "r") as fh:
        history_text = fh.read()

    blocks = _split_status_blocks(history_text)
    matched = [b for b in blocks if date_filter in b]

    if not matched:
        print(f"  No update records found for date: {date_filter}", file=sys.stderr)
        sys.exit(1)

    print(f"  {len(matched)} record(s) found for {date_filter}\n", file=sys.stderr)
    for block in matched:
        print(block)
        print()
    sys.exit(0)


