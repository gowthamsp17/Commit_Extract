def select_columns(df, branch, fields):
    if not fields or "all" in fields:
        return df

    cols = ["Branch"]
    for f in fields:
        if f == "fixes":
            # Include all Fix-N columns in a logical order per fix entry:
            # hash, link, author-date, commit-date, description, subsystem, files, config
            fix_nums = sorted(set(
                c.split()[0]  # "Fix-N"
                for c in df.columns if c.startswith("Fix-")
            ))
            for fn in fix_nums:
                for pattern in [
                    f"{fn} {branch} Commit Hash",
                    f"{fn} {branch} GitHub Link",
                    f"{fn} {branch} AuthorDate",
                    f"{fn} {branch} CommitDate",
                    f"{fn} Description",
                    f"{fn} Subsystem",
                    f"{fn} Files Changed",
                    f"{fn} CONFIG_ Parameters",
                ]:
                    if pattern in df.columns:
                        cols.append(pattern)
        elif f in FIELD_MAP:
            cols += [c for c in FIELD_MAP[f](branch) if c in df.columns]
        else:
            print(f"⚠  Unknown field '{f}' — skipped", file=sys.stderr)

    seen, final = set(), []
    for c in cols:
        if c not in seen and c in df.columns:
            seen.add(c)
            final.append(c)
    return df[final] if final else df


# ── Output rendering ──────────────────────────────────────────────────────

def colourize_columns(df):
    if not _supports_colour():
        return df
    df = df.copy()
    if "Severity" in df.columns:
        df["Severity"] = df["Severity"].apply(
            lambda s: f"{SEV_COLOR.get(s, '')}{s}{RST}" if pd.notna(s) and s else s
        )
    # Applicability columns are branch-prefixed e.g. "6.1.y Applicability"
    for col in df.columns:
        if col.endswith(" Applicability") and not col.startswith("Version"):
            df[col] = df[col].apply(
                lambda s: f"{APPLIC_COLOR.get(s, '')}{s}{RST}" if pd.notna(s) and s else s
            )
    if "Version Applicability" in df.columns:
        df["Version Applicability"] = df["Version Applicability"].apply(
            lambda s: f"{VER_APPLIC_COLOR.get(s, '')}{s}{RST}" if pd.notna(s) and s else s
        )
    return df


def render_table(df, no_header):
    if df.empty:
        return ""
    display = colourize_columns(df).fillna("")
    if HAS_TABULATE:
        return tabulate(display, headers=[] if no_header else "keys",
                        tablefmt="simple", showindex=False, disable_numparse=True, maxcolwidths=60)
    return display.to_string(index=False, header=not no_header)


def render_output(df, fmt, no_header):
    if df.empty:
        return ""
    if fmt == "table":  return render_table(df, no_header)
    if fmt == "csv":    return df.to_csv(index=False, header=not no_header)
    if fmt == "tsv":    return df.to_csv(index=False, sep="\t", header=not no_header)
    if fmt == "json":   return df.to_json(orient="records", indent=2)
    return render_table(df, no_header)


def print_stats(df, branch):
    total = len(df)
    print(f"\n  Severity")
    for sev in ALL_SEVERITIES:
        n = (df["Severity"] == sev).sum()
        if n:
            pct = n / total * 100
            bar = "█" * max(1, int(pct / 2))
            print(f"    {sev:<12}  {n:>6,}  {pct:4.1f}%  {bar}")

    applic_col = f"{branch} Applicability"
    if applic_col in df.columns:
        print(f"\n  Applicability")
        for a in ALL_APPLICABILITY:
            n = (df[applic_col] == a).sum()
            if n:
                pct = n / total * 100
                print(f"    {a:<22}  {n:>6,}  {pct:4.1f}%")

    if "Matched CVEs" in df.columns:
        n_cve = df["Matched CVEs"].notna().sum()
        print(f"\n  CVE-matched commits  {n_cve:,} / {total:,}  ({n_cve/total*100:.1f}%)")

    cc_s = (df["Cc stable"].str.strip().str.lower() == "yes").sum()
    print(f"  Cc stable            {cc_s:,}")

    ver_col = f"{branch} First Version"
    if ver_col in df.columns:
        versions = df[ver_col].dropna()
        if not versions.empty:
            sv = sorted(versions.unique(), key=parse_version)
            print(f"\n  Version range  {sv[0]}  →  {sv[-1]}  ({len(sv)} distinct versions)")


# ── Save helpers ──────────────────────────────────────────────────────────

def save_csv(results, path, quiet):
    combined = pd.concat(results.values(), ignore_index=True)
    combined.to_csv(path, index=False)
    if not quiet:
        print(f"  ✔  Saved CSV   → {path}  ({len(combined):,} rows)", file=sys.stderr)


def save_excel(results, path, quiet):
    try:
        import openpyxl
    except ImportError:
        sys.exit("✖  openpyxl required:  pip install openpyxl")
    with pd.ExcelWriter(path, engine="openpyxl") as writer:
        for label, df in results.items():
            df.to_excel(writer, sheet_name=label[:31], index=False)
        combined = pd.concat(results.values(), ignore_index=True)
        combined.to_excel(writer, sheet_name="combined", index=False)
    if not quiet:
        total = sum(len(d) for d in results.values())
        print(f"  ✔  Saved Excel → {path}  ({total:,} rows, {len(results)+1} sheets)", file=sys.stderr)


def save_json(results, path, quiet):
    combined = pd.concat(results.values(), ignore_index=True)
    combined.to_json(path, orient="records", indent=2)
    if not quiet:
        print(f"  ✔  Saved JSON  → {path}  ({len(combined):,} rows)", file=sys.stderr)


# ── Main ──────────────────────────────────────────────────────────────────

def main():
    parser = build_parser()
    args   = parser.parse_args()

    # ── Always show last-updated banner ───────────────────────────────────
    print_last_updated(status_path=os.path.join(
        args.data_dir if args.data_dir else os.getcwd(), STATUS_FILE
    ), quiet=getattr(args, "quiet", False))

    # ── --updates [--date YYYY-MM-DD] ─────────────────────────────────────
    if getattr(args, "updates", False):
        base = args.data_dir if args.data_dir else os.getcwd()
        cmd_show_updates(
            status_path=os.path.join(base, STATUS_FILE),
            status_hist_path=os.path.join(base, STATUS_HISTORY_FILE),
            date_filter=getattr(args, "date", None),
        )
        # cmd_show_updates calls sys.exit() so execution stops here

    branches = args.branch or ALL_BRANCHES
    df_paths, cve_path, _status, _status_hist = resolve_paths(args)

    for attr, flag in [("date_from", "--date-from"), ("date_to", "--date-to")]:
        val = getattr(args, attr, None)
        if val and not parse_date(val):
            parser.error(f"{flag}: invalid date '{val}'. Use YYYY-MM-DD.")

    for attr, flag in [("version_from", "--version-from"), ("version_to", "--version-to"), ("version_applicable", "--version-applicable")]:
        val = getattr(args, attr, None)
        if val:
            parts = str(val).split(".")
            if not all(p.isdigit() for p in parts):
                parser.error(f"{flag}: invalid version '{val}'. Use format like 6.1.76")

    if args.version_from and args.version_to:
        if parse_version(args.version_from) > parse_version(args.version_to):
            parser.error(
                f"--version-from ({args.version_from}) must be <= --version-to ({args.version_to})"
            )

    needs_cve = bool(args.cve or args.cve_xref or args.cve_annotate)

    cve_df = None
    if needs_cve:
        cve_df = load_csv(cve_path, "CVE data", args.quiet)
        if cve_df is None:
            sys.exit(1)

    cve_hashes = []
    if args.cve and cve_df is not None:
        matched_cves = filter_cve_records(cve_df, args.cve)
        if not args.quiet:
            print(f"\nCVE records  ({len(matched_cves):,} matched)\n", file=sys.stderr)
        if not matched_cves.empty:
            cve_display_cols = ["CVE Number", "Description"] + [
                f"{b} Fixed Commit" for b in branches
                if f"{b} Fixed Commit" in matched_cves.columns
            ]
            print(render_output(matched_cves[cve_display_cols], args.format, args.no_header))
            print()
            for b in branches:
                col = f"{b} Fixed Commit"
                if col in matched_cves.columns:
                    cve_hashes += matched_cves[col].dropna().astype(str).tolist()
        else:
            print(f"  No CVE records found for: {', '.join(args.cve)}", file=sys.stderr)

    if not args.quiet:
        print(file=sys.stderr)

    all_results = {}

    for branch in branches:
        df = load_csv(df_paths[branch], branch, args.quiet)
        if df is None:
            continue

        cve_short = cve_short_hashes(cve_df, branch) if cve_df is not None else None
        cve_map   = build_cve_map(cve_df, branch)    if cve_df is not None else {}

        filtered = apply_filters(df, branch, args, cve_short, cve_hashes)

        # --version-applicable: compute fix-date vs version-date applicability
        # NOTE: version date must be looked up in the full df (before filters),
        # because --version-from/--version-to may have excluded that version's rows.
        if args.version_applicable:
            filtered = compute_version_applicability(filtered, branch, args.version_applicable, full_df=df)

        # Always attach CVE column when CVE data is loaded (annotate or xref or --cve)
        if cve_df is not None:
            hash_col = f"{branch} Commit Hash"
            filtered["Matched CVEs"] = filtered[hash_col].apply(
                lambda h: hash_to_cves(h, cve_map)
            )

        filtered.insert(0, "Branch", branch)
        all_results[branch] = filtered

    total = sum(len(d) for d in all_results.values())
    if total == 0:
        print("  No results found.", file=sys.stderr)
        sys.exit(1)

    for branch, df in all_results.items():
        if df.empty:
            continue

        if not args.quiet:
            ver_info = ""
            if (args.version_from or args.version_to) and f"{branch} First Version" in df.columns:
                versions = sorted(df[f"{branch} First Version"].dropna().unique(), key=parse_version)
                if versions:
                    ver_info = f"  (versions {versions[0]} → {versions[-1]})"

            print(
                f"\n{'─'*60}\n"
                f"  {branch}  —  {len(df):,} commit(s){ver_info}\n"
                f"{'─'*60}",
                file=sys.stderr,
            )

        if args.stats:
            print_stats(df, branch)

        if not args.count:
            base_fields = args.fields or DEFAULT_FIELDS
            if args.version_applicable and "ver-applicable" not in base_fields and "all" not in base_fields:
                base_fields = list(base_fields) + ["ver-applicable"]
            display = select_columns(df, branch, base_fields)
            if args.limit > 0:
                display = display.head(args.limit)
            out = render_output(display, args.format, args.no_header)
            if out:
                print(out)

    if not args.quiet:
        branch_summary = "  ".join(
            f"{b}: {len(d):,}" for b, d in all_results.items() if not d.empty
        )
        print(
            f"\n{'─'*60}\n"
            f"  Total: {total:,} commit(s)   {branch_summary}\n"
            f"{'─'*60}\n",
            file=sys.stderr,
        )

    non_empty = {b: d for b, d in all_results.items() if not d.empty}
    if args.save_csv:
        save_csv(non_empty, args.save_csv, args.quiet)
    if args.save_excel:
        save_excel(non_empty, args.save_excel, args.quiet)
    if args.save_json:
        save_json(non_empty, args.save_json, args.quiet)

    sys.exit(0)


if __name__ == "__main__":
    main()
